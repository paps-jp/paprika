---
layout: null
---
[
  {% assign pages = site.pages | sort: "title" %}
  {% for page in pages %}
    {% comment %}
      Skip search/404 and *internal design docs* — they show up at the top of
      search results because they're long with many keyword hits, but they're
      not public-user content. Excluded explicitly by URL.
    {% endcomment %}
    {% if page.path == "search.json" or page.path == "404.html" %}{% continue %}{% endif %}
    {% if page.path == "admin-service-plan.md" %}{% continue %}{% endif %}
    {% if page.path == "architecture/hub-multiprocess.md" %}{% continue %}{% endif %}
    {% if page.path == "deploy.md" %}{% continue %}{% endif %}
    {% if page.search == false %}{% continue %}{% endif %}
    {% if page.title %}
    {
      "url": {{ page.url | relative_url | jsonify }},
      "title": {{ page.title | jsonify }},
      "description": {{ page.description | default: "" | jsonify }},
      "content": {{ page.content | strip_html | strip_newlines | normalize_whitespace | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endif %}
  {% endfor %}
]
