{
  "manifest_version": 3,
  "name": "Paprika Bridge",
  "version": "0.2.0",
  "description": "Connect Chrome to a Paprika Hub: push cookies for the host registry, send URLs / clipboard to running jobs, and assist copy-paste workflows.",
  "permissions": [
    "cookies",
    "storage",
    "activeTab",
    "tabs",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Paprika Bridge",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
