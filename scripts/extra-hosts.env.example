# Copy to scripts/extra-hosts.env and edit.
# deploy.sh rsyncs the working tree to these hosts so helper scripts
# (start-qwen-vl.sh, sync-workers.sh, ...) stay current. Nothing
# else is touched on those hosts -- vLLM and other services are
# operator-managed.

# Space-separated SSH targets.
EXTRA_HOSTS="www@<gpu-host>"

# Where on the remote host to land the working tree.
EXTRA_REMOTE_PATH="/home/www/paprika"
