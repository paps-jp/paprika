# Copy to scripts/llm.env and edit if your GPU box isn't the default
# www@<gpu-host>.  switch-llm.sh sources this file.

# SSH target for the GPU box.
GPU_HOST="www@<gpu-host>"

# IP / hostname used to build AGENT_LLM_URL (must be reachable from the
# hub CT and any external workers).
GPU_HOST_IP="<gpu-host>"

# Where the paprika working tree lives on the GPU box (deploy.sh rsyncs
# the repo here, including start-gpt-oss.sh / start-qwen-vl.sh).
GPU_PAPRIKA_PATH="/home/www/paprika"

# vLLM ports for each model.  Defaults assume gpt-oss is on 15080 and
# Qwen2.5-VL on 15082 so they could in principle coexist on different
# GPUs.  On a single 80GB card we still run one at a time.
GPT_OSS_PORT="15080"
QWEN_VL_PORT="15082"

# Python venv on the GPU host that has vLLM installed.  start-*.sh
# source $VENV_PATH/bin/activate before launching python.  Set to ""
# to disable (if you already activate the venv before running).
VENV_PATH="/home/www/gptoss"
