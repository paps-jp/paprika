# paprika の環境変数テンプレート
#
# 使い方:
#   cp .env.example .env
#   # 自分の環境に合わせて編集
#   docker compose up -d        # hub 同居構成の場合
#   または
#   docker compose -f docker-compose-worker.yml up -d   # 別ホストで worker を立てる場合
#
# このファイル自体は git で公開されています。実際の値 (.env) は
# .gitignore で除外されているのでコミットされません。

# ===========================================================================
# Worker → Hub 接続
# ===========================================================================

# Hub の WebSocket URL。worker はここに常時接続して制御メッセージを受け取る。
# 同じマシン (compose) なら paprika.lan のままでも動く (compose の内部 DNS が解決)。
# 別ホストの worker から繋ぐ場合は hub の LAN 名 / IP に書き換える。
HUB_URL=ws://paprika.lan:8000

# Worker WS handshake 認証用シークレット。Hub と Worker で同じ値を設定する。
# 空のままにすると認証なし (LAN-trusted 前提)。
WORKER_SECRET=

# ===========================================================================
# Worker のブラウザ Lane 設定
# ===========================================================================

# Lane (= 1 Chrome プロセス + 1 noVNC viewer) の数。
# 1 lane あたり ~500MB-1GB RAM 消費。
LANE_POOL=2

# 同時実行可能ジョブ数。LANE_POOL と同じ値にするのが普通。
MAX_CONCURRENT=2

# noVNC URL のホスト部。Hub の admin UI が "lane 0 をライブで見る" リンクを
# 作るときに使う。worker が動いているホストの LAN IP / DNS 名を入れる。
# 例:   NOVNC_PUBLIC_HOST=worker1.lan
#       NOVNC_PUBLIC_HOST=10.0.0.50
# 未設定 (localhost) のままだと、Hub の admin UI から見えなくなる。
# 注: Hub 側で自動補正もされるので未設定でも動作する。
NOVNC_PUBLIC_HOST=

# noVNC のベースポート。Lane 0 がこのポート、Lane 1 がこの +1 …
NOVNC_BASE_PORT=6080

# Worker のラベル (任意)。複数 worker を分類するのに使う。
# 例:   LABELS=region=tokyo,role=heavy
LABELS=region=local

# ===========================================================================
# LLM 連携 (オプション)
# ===========================================================================

# AGENT_URL: paprika-runner / page.agent() が使う text LLM プロキシ
# 通常は compose 内の agent サービスを指すので変更不要
# AGENT_URL=http://agent:8001

# AGENT_LLM_URL: text LLM 本体 (Qwen 2.5-VL の vLLM サーバなど) の直 URL
# JP -> EN 自動翻訳や codegen-loop 用
# AGENT_LLM_URL=http://your-gpu-host:15082
# AGENT_MODEL_NAME=qwen2.5-vl-72b

# COGAGENT_URL: vision LLM (CogAgent) endpoint
# vision-agent モードや page.agent(engine="cogagent") で使う
# COGAGENT_URL=http://your-gpu-host:15083

# ---------------------------------------------------------------------------
# GPU が無い場合
# ---------------------------------------------------------------------------
# hub / worker 自体は GPU 不要 (python:3.13-slim ベース)。LLM を呼ばない
# Fetch / Macro(Simple) モードはそのまま動く。AI / codegen-loop /
# vision-agent モードだけが LLM (= GPU 推奨) を必要とする。
#
# GPU 箱が無いまま AI モードも使いたい場合は LLM を CPU で動かす:
#   docker compose -f docker-compose-agent.cpu.yml up -d --build
#   docker compose -f docker-compose-agent.cpu.yml exec ollama ollama pull qwen2.5:7b
# そのうえで下記を CPU LLM のホストに向ける (同一ホストなら LAN IP/DNS):
#   AGENT_URL=http://<cpu-llm-host>:8001
#   AGENT_LLM_URL=http://<cpu-llm-host>:11434
#   CODEGEN_LLM_URL=http://<cpu-llm-host>:11434/v1
# CPU 推論は遅いので注意。小さめモデル (qwen2.5:3b 等) も可。

# ===========================================================================
# Hub 固有 (docker-compose.yml 用)
# ===========================================================================

# Hub の公開 URL。worker が asset upload に使う。
# 別ネットワークから worker を繋ぐときは LAN IP / DNS 名に。
# PUBLIC_BASE_URL=http://paprika.lan:8000

# Codegen 用 LLM (Qwen 2.5-VL など) の OpenAI-compat エンドポイント
# CODEGEN_LLM_URL=http://your-gpu-host:15082
# CODEGEN_MODEL_NAME=qwen2.5-vl-72b
